# ── Mode ────────────────────────────────────────────────────
# PAPER = no real transactions. LIVE = real money.
EXECUTOR_MODE=PAPER

# ── Helius RPC (required for live scanner) ──────────────────
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ── Wallet (LIVE mode only) ──────────────────────────────────
WALLET_PRIVATE_KEY=

# ── Risk Controls ────────────────────────────────────────────
MAX_OPEN_POSITIONS=5
MAX_POSITION_SIZE_SOL=0.5
MAX_TOKEN_EXPOSURE_PCT=10
MAX_STRATEGY_EXPOSURE_PCT=30
DAILY_LOSS_LIMIT_SOL=2
TRADE_TIME_LIMIT_MS=1800000

# ── Safety ───────────────────────────────────────────────────
SAFETY_RISK_THRESHOLD=60
STRATEGY_DRAWDOWN_LIMIT=0.3

# ── Jito (LIVE mode) ─────────────────────────────────────────
JITO_TIP_LAMPORTS=500000

# ── Server ───────────────────────────────────────────────────
WS_PORT=8080
HTTP_PORT=3001

# ── Storage ──────────────────────────────────────────────────
DB_PATH=data/bot.db

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
