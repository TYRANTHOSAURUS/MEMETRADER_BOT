{
  "name": "memetrader-bot",
  "version": "0.1.0",
  "description": "Modular Solana memecoin trading bot",
  "main": "src/app.ts",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "start": "tsx src/app.ts",
    "ui": "cd ui && npm run dev",
    "start:all": "concurrently --names \"BOT,UI\" --prefix-colors \"green,cyan\" \"npm run dev\" \"npm run ui\"",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.3",
    "bs58": "^5.0.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "uuid": "^9.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
